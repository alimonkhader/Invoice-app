<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "InvoiceApp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="page-shell">
      <header class="navbar navbar-expand-lg app-navbar sticky-top">
        <div class="container py-3">
          <div>
            <%= link_to "Invoice App", root_path, class: "navbar-brand fw-bold brand" %>
            <p class="nav-caption mb-0">Create, share, and organize invoices with a calm green workspace.</p>
          </div>
          <nav class="ms-auto d-flex gap-2">
            <%= link_to "Invoices", invoices_path, class: "btn btn-outline-secondary btn-sm" %>
            <%= link_to "New Invoice", root_path, class: "btn btn-success btn-sm" %>
          </nav>
        </div>
      </header>

      <main class="container app-main">
        <% if notice.present? %>
          <div class="alert alert-success shadow-sm app-alert"><%= notice %></div>
        <% end %>

        <% if alert.present? %>
          <div class="alert alert-danger shadow-sm app-alert"><%= alert %></div>
        <% end %>

        <%= yield %>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
