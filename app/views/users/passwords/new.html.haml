- content_for :title, "Forgot Password"

.page-hero.page-hero--tight
  .page-hero__content
    %span.eyebrow Password recovery
    %h1.page-title Reset your password
    %p.page-subtitle Enter your account email and we will send reset instructions.
  .page-hero__panel
    %span.hero-pill Recovery email
    %p.mb-0 The reset link will be delivered to the email connected to your account.

.form-card
  = form_with model: resource, as: resource_name, url: password_path(resource_name), method: :post do |f|
    .section-card
      .section-head
        %div
          %h3.section-title Email address
          %p.section-copy Only purchased account users can receive password reset instructions here.
      .form-grid
        .field
          = f.label :email, "Email"
          = f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "you@example.com"

    .actions
      = f.submit "Send reset instructions", class: "btn btn-primary"
      = link_to "Back to login", login_path, class: "btn btn-outline-secondary"
