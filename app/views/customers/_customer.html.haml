.card{id: dom_id(customer)}
  .card-row
    %div
      %span.card-kicker Customer
      %h3.card-title= customer.name
      %p.muted.mb-0= customer.email
    = link_to "View", customer, class: "btn btn-secondary btn-sm"

  .meta-grid
    .meta-item
      %span.meta-label Phone
      %span.meta-value= customer.phone.presence || "N/A"
    .meta-item
      %span.meta-label Email
      %span.meta-value= customer.email.presence || "N/A"
