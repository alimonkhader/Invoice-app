.card
  .card-row
    %div
      %h2{ style: "margin: 0;" }= "Invoice ##{@invoice.invoice_number.presence || @invoice.id}"
      %p.muted.mb-0 Generated and ready to share
    = link_to "Download PDF", invoice_path(@invoice, format: :pdf), class: "btn btn-outline-success btn-sm"

  .meta-grid
    .meta-item
      %span.meta-label Date
      %span.meta-value= @invoice.date || @invoice.created_at&.to_date
    .meta-item
      %span.meta-label Customer
      %span.meta-value= @invoice.customer&.name || "N/A"
    .meta-item
      %span.meta-label Company
      %span.meta-value= @invoice.company_name

  %h3{ style: "margin-top: 1rem;" } Invoice Summary
  .summary
    %p
      %strong Subtotal:
      = number_to_currency(@invoice.total.to_f, unit: "₹", precision: 2)
    %p
      %strong CGST (9%):
      = number_to_currency(@invoice.cgst.to_f, unit: "₹", precision: 2)
    %p
      %strong SGST (9%):
      = number_to_currency(@invoice.sgst.to_f, unit: "₹", precision: 2)
    %p
      %strong Final Total:
      = number_to_currency(@invoice.final_total.to_f, unit: "₹", precision: 2)

.actions
  = link_to "Edit invoice", edit_invoice_path(@invoice), class: "btn btn-primary"
  = button_to "Send Email", send_email_invoice_path(@invoice), method: :post, class: "btn btn-outline-success"
  = link_to "Send WhatsApp", share_whatsapp_invoice_path(@invoice), class: "btn btn-success"
  = link_to "Back to invoices", invoices_path, class: "btn btn-secondary"
  = button_to "Delete invoice", @invoice, method: :delete, class: "btn btn-danger"