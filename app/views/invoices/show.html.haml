.page-hero.page-hero--tight
  .page-hero__content
    %span.eyebrow Invoice details
    %h1.page-title= "Invoice ##{@invoice.invoice_number.presence || @invoice.id}"
    %p.page-subtitle Generated and ready to share across PDF, email, and WhatsApp.
  .page-hero__panel
    = link_to "Download PDF", invoice_path(@invoice, format: :pdf), class: "btn btn-outline-success"

.detail-grid
  .card
    .card-row
      %div
        %h2.card-title Invoice overview
        %p.muted.mb-0 Core billing information for this invoice.

    .meta-grid
      .meta-item
        %span.meta-label Date
        %span.meta-value= @invoice.date || @invoice.created_at&.to_date
      .meta-item
        %span.meta-label Customer
        %span.meta-value= @invoice.customer&.name || "N/A"
      .meta-item
        %span.meta-label Company
        %span.meta-value= @invoice.company_name
      .meta-item
        %span.meta-label Tax mode
        %span.meta-value= @invoice.gst_enabled? ? "GST enabled" : "GST disabled"

  .card.summary-card.summary-card--totals
    .summary-card__label Invoice summary
    .summary-line
      %span Subtotal
      %strong= number_to_currency(@invoice.total.to_f, unit: "₹", precision: 2)
    - if @invoice.gst_enabled?
      .summary-line
        %span CGST (9%)
        %strong= number_to_currency(@invoice.cgst.to_f, unit: "₹", precision: 2)
      .summary-line
        %span SGST (9%)
        %strong= number_to_currency(@invoice.sgst.to_f, unit: "₹", precision: 2)
    - else
      .summary-line
        %span GST
        %strong Not applied
    .summary-line.summary-line--total
      %span Final Total
      %strong= number_to_currency(@invoice.final_total.to_f, unit: "₹", precision: 2)

.actions
  = link_to "Edit invoice", edit_invoice_path(@invoice), class: "btn btn-primary"
  = button_to "Send Email", send_email_invoice_path(@invoice), method: :post, class: "btn btn-outline-success"
  = link_to "Send WhatsApp", share_whatsapp_invoice_path(@invoice), class: "btn btn-success"
  = link_to "Back to invoices", invoices_path, class: "btn btn-secondary"
  = button_to "Delete invoice", @invoice, method: :delete, class: "btn btn-danger"
